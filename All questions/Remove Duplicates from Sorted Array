class Solution {
    public int removeDuplicates(int[] nums) {
        int count=0;
        Set<Integer> set=new HashSet<>();
        for(int num : nums){
            set.add(num);
        }
        List<Integer> l=new ArrayList<>(set);
        Collections.sort(l);
        int index = 0;
        for (int num : l) {
            nums[index++] = num;
        }
        
        return set.size();
    }
}
