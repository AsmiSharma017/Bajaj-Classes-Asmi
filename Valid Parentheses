class Solution {
    public boolean isValid(String s) {
        Stack<Character> stack = new Stack<>();

        for(char c : s.toCharArray()) {

            if(c == '(' || c == '{' || c == '[') {
                stack.push(c);
            } else {

                if(stack.isEmpty()) {
                    return false;
                }

                if(c == ')' && stack.get(stack.size()-1) == '(') {
                    stack.pop();
                }
                else if(c == '}' && stack.get(stack.size()-1) == '{') {
                    stack.pop();
                }
                else if(c == ']' && stack.get(stack.size()-1) == '[') {
                    stack.pop();
                }
                else {
                    return false;
                }
            }
        }

        return stack.isEmpty();
    }
}
